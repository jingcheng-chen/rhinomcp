{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "delete_result.json",
  "title": "DeleteResult Response",
  "description": "Result of a delete operation",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "../common/definitions.json#/$defs/guid",
      "description": "GUID of deleted object (single-target delete)"
    },
    "name": {
      "type": "string",
      "description": "Name of deleted object (single-target delete)"
    },
    "deleted": {
      "type": "boolean",
      "description": "Whether deletion was successful"
    },
    "count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of objects deleted (delete-all)"
    },
    "scope": {
      "type": "string",
      "enum": ["all"],
      "description": "Set to 'all' when deleting every object in the document"
    }
  },
  "required": ["deleted"]
}
