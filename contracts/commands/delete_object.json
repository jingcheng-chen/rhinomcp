{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "delete_object.json",
  "title": "DeleteObject Command",
  "description": "Delete an object from Rhino",
  "type": "object",
  "properties": {
    "id": {
      "$ref": "../common/definitions.json#/$defs/guid",
      "description": "GUID of the object to delete"
    },
    "name": {
      "type": "string",
      "description": "Name of the object to delete (alternative to id)"
    },
    "all": {
      "type": "boolean",
      "const": true,
      "description": "Delete all objects in the document. Must be true if present."
    }
  },
  "oneOf": [
    { "required": ["id"], "not": { "anyOf": [ { "required": ["name"] }, { "required": ["all"] } ] } },
    { "required": ["name"], "not": { "anyOf": [ { "required": ["id"] }, { "required": ["all"] } ] } },
    { "required": ["all"], "not": { "anyOf": [ { "required": ["id"] }, { "required": ["name"] } ] } }
  ],
  "additionalProperties": false
}
