{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gh_mutate_graph.json",
  "title": "gh_mutate_graph",
  "description": "Batch edit an existing or new Grasshopper graph in one transaction. Use this for rewiring, inserting components, updating controls, deleting objects, grouping, preview policy, layout, recompute, and verification. Operation selectors such as source, target, layout.targets, groups.targets, and preview_policy targets can reference request-local aliases, persisted aliases, Grasshopper instance GUIDs, or nicknames.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "graph_id": { "type": "string", "minLength": 1 },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/operation" }
    },
    "preview_policy": { "$ref": "#/$defs/preview_policy" },
    "groups": {
      "type": "array",
      "items": { "$ref": "#/$defs/group" }
    },
    "layout": {
      "oneOf": [
        { "type": "boolean" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "targets": { "$ref": "#/$defs/selectors" },
            "x_spacing": { "type": "number", "exclusiveMinimum": 0, "default": 220 },
            "y_spacing": { "type": "number", "exclusiveMinimum": 0, "default": 90 },
            "max_columns": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "description": "Wrap graph-depth layout after this many columns to avoid a very long horizontal canvas."
            },
            "start_position": { "$ref": "#/$defs/position" }
          }
        }
      ]
    },
    "verify": { "$ref": "#/$defs/verify" },
    "fail_on_verification_error": { "type": "boolean", "default": false },
    "recompute": { "type": "boolean", "default": true },
    "rollback_on_error": { "type": "boolean", "default": true },
    "open_canvas": {
      "type": "boolean",
      "default": true,
      "description": "Open Grasshopper and make the working document active before mutating, so live preview and screenshots can see the edited definition."
    }
  },
  "required": ["operations"],
  "$defs": {
    "guid": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
    },
    "alias": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z_][A-Za-z0-9_-]*$"
    },
    "selector": {
      "type": "string",
      "minLength": 1
    },
    "selectors": {
      "type": "array",
      "items": { "$ref": "#/$defs/selector" },
      "minItems": 1
    },
    "position": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 2,
      "maxItems": 2
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "op": {
          "type": "string",
          "enum": ["create", "connect", "set", "update", "disconnect", "delete", "recompute"]
        },
        "alias": {
          "$ref": "#/$defs/alias",
          "description": "Request-local alias for a newly created object, or a persisted alias to assign during update."
        },
        "target": {
          "$ref": "#/$defs/selector",
          "description": "Target object selector. Can be a request-local alias, persisted alias, Grasshopper instance GUID, or nickname."
        },
        "source": {
          "$ref": "#/$defs/selector",
          "description": "Source object selector. Can be a request-local alias, persisted alias, Grasshopper instance GUID, or nickname."
        },
        "component_name": { "type": "string", "minLength": 1, "description": "Component display name or common alias for create operations." },
        "component_guid": { "$ref": "#/$defs/guid", "description": "Grasshopper component GUID for create operations. Prefer GUIDs for ambiguous component names." },
        "guid": { "$ref": "#/$defs/guid", "description": "Alias for component_guid." },
        "position": { "$ref": "#/$defs/position" },
        "nickname": { "type": "string", "minLength": 1 },
        "new_nickname": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "graph_id": { "type": "string", "minLength": 1 },
        "value": {
          "description": "Value to apply for set/create/upsert-style control operations. Sliders accept numbers; toggles accept booleans; panels accept strings."
        },
        "min": { "type": "number", "description": "Number Slider minimum." },
        "max": { "type": "number", "description": "Number Slider maximum." },
        "decimals": { "type": "integer", "minimum": 0, "maximum": 12, "description": "Number Slider decimal places." },
        "content": { "type": "string", "description": "Panel text content." },
        "text": { "type": "string", "description": "Alias for Panel text content." },
        "preview": { "type": "boolean" },
        "enabled": { "type": "boolean" },
        "input_index": { "type": "integer", "minimum": 0, "description": "Input parameter index for set/update-style parameter selection." },
        "input_name": { "type": "string", "minLength": 1, "description": "Input parameter name or nickname for set/update-style parameter selection." },
        "output_index": { "type": "integer", "minimum": 0, "description": "Output parameter index for verification or generic output selection." },
        "output_name": { "type": "string", "minLength": 1, "description": "Output parameter name or nickname for verification or generic output selection." },
        "source_output_index": { "type": "integer", "minimum": 0, "description": "Output parameter index on source for connect/disconnect. Prefer source_output_name when a stable port nickname is known." },
        "source_output_name": { "type": "string", "minLength": 1, "description": "Output parameter name or nickname on source for connect/disconnect, for example 'R' or 'Result'." },
        "target_input_index": { "type": "integer", "minimum": 0, "description": "Input parameter index on target for connect/disconnect. Prefer target_input_name when a stable port nickname is known." },
        "target_input_name": { "type": "string", "minLength": 1, "description": "Input parameter name or nickname on target for connect/disconnect, for example 'L' or 'List'." },
        "disconnect_all": { "type": "boolean" }
      },
      "required": ["op"]
    },
    "preview_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "type": "string", "enum": ["only", "show", "hide"] },
        "targets": { "$ref": "#/$defs/selectors" },
        "scope": { "$ref": "#/$defs/selectors" },
        "graph_id": { "type": "string", "minLength": 1 }
      },
      "required": ["mode", "targets"]
    },
    "group": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "nickname": { "type": "string", "minLength": 1 },
        "alias": { "$ref": "#/$defs/alias" },
        "role": { "type": "string", "minLength": 1 },
        "targets": { "$ref": "#/$defs/selectors" },
        "color": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0, "maximum": 255 },
          "minItems": 3,
          "maxItems": 3
        }
      },
      "anyOf": [
        { "required": ["name"] },
        { "required": ["label"] },
        { "required": ["nickname"] }
      ]
    },
    "verify": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "run_solution": { "type": "boolean", "default": true },
        "expect_no_runtime_warnings": { "type": "boolean", "default": false },
        "outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "target": { "$ref": "#/$defs/selector" },
              "alias": { "$ref": "#/$defs/selector" },
              "output_index": { "type": "integer", "minimum": 0 },
              "output_name": { "type": "string", "minLength": 1 },
              "expect_count_min": { "type": "integer", "minimum": 0 },
              "expect_count_exact": { "type": "integer", "minimum": 0 },
              "expect_type": { "type": "string", "minLength": 1 },
              "expect_all_type": { "type": "string", "minLength": 1 },
              "expect_solid": { "type": "boolean" },
              "expect_all_solid": { "type": "boolean" },
              "expect_no_runtime_warnings": { "type": "boolean" },
              "max_items": { "type": "integer", "minimum": 0, "maximum": 100 }
            },
            "anyOf": [
              { "required": ["target"] },
              { "required": ["alias"] }
            ]
          }
        }
      },
      "required": ["outputs"]
    }
  },
  "examples": [
    {
      "graph_id": "ExistingGraph",
      "operations": [
        {
          "op": "disconnect",
          "source": "11111111-1111-1111-1111-111111111111",
          "source_output_name": "G",
          "target": "22222222-2222-2222-2222-222222222222",
          "target_input_name": "L"
        },
        {
          "op": "create",
          "alias": "flatten_inserted",
          "component_name": "Flatten Tree",
          "nickname": "Flatten",
          "role": "utility"
        },
        {
          "op": "connect",
          "source": "11111111-1111-1111-1111-111111111111",
          "source_output_name": "G",
          "target": "flatten_inserted"
        },
        {
          "op": "connect",
          "source": "flatten_inserted",
          "target": "22222222-2222-2222-2222-222222222222",
          "target_input_name": "L"
        },
        { "op": "recompute" }
      ],
      "layout": {
        "enabled": true,
        "targets": [
          "11111111-1111-1111-1111-111111111111",
          "flatten_inserted",
          "22222222-2222-2222-2222-222222222222"
        ],
        "max_columns": 4
      },
      "recompute": true,
      "rollback_on_error": true
    }
  ]
}
