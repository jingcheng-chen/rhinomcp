{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "redo.json",
  "title": "Redo Command",
  "description": "Redo the last N undone operations in the active Rhino document",
  "type": "object",
  "properties": {
    "steps": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    }
  },
  "additionalProperties": false
}
